{
  "entities": {
    "Class": {
      "title": "Class",
      "description": "Represents a classroom or course.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the class (e.g. Physics 101)" },
        "description": { "type": "string", "description": "Optional description." },
        "teacherId": { "type": "string", "description": "UID of the teacher." },
        "studentCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "teacherId", "createdAt"]
    },
    "Student": {
      "title": "Student",
      "description": "Represents a student enrolled in a class.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "classId": { "type": "string", "description": "The class this student belongs to." },
        "teacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "classId", "teacherId", "createdAt"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "A task assigned to a student within a class.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "classId": { "type": "string" },
        "studentId": { "type": "string" },
        "teacherId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "dueDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "classId", "studentId", "teacherId", "status", "createdAt"]
    }
  },
  "firestore": {
    "classes": {
      "schema": "Class",
      "description": "Collection of classrooms."
    },
    "students": {
      "schema": "Student",
      "description": "Collection of students."
    },
    "assignments": {
      "schema": "Assignment",
      "description": "Collection of specific assignments."
    }
  }
}
